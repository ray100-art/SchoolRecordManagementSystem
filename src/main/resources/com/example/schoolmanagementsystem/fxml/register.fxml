<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.schoolmanagementsystem.controller.RegisterController"
           style="-fx-background-color: linear-gradient(to bottom right, #1b5e20, #0d47a1);">

    <VBox alignment="CENTER" spacing="14" maxWidth="420"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 40;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 20, 0, 0, 10);">

        <Label text="🏫" style="-fx-font-size: 40;" />
        <Label text="Create an Account"
               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a237e;" />
        <Label text="School Management System" style="-fx-font-size: 12; -fx-text-fill: #999;" />

        <Separator />

        <VBox spacing="4">
            <Label text="Full Name *" style="-fx-font-size: 12; -fx-text-fill: #555;" />
            <TextField fx:id="fullNameField" promptText="e.g. Brian Ndungu"
                       style="-fx-padding: 9; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="4">
            <Label text="Email" style="-fx-font-size: 12; -fx-text-fill: #555;" />
            <TextField fx:id="emailField" promptText="you@school.ac.ke"
                       style="-fx-padding: 9; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="4">
            <Label text="Username *" style="-fx-font-size: 12; -fx-text-fill: #555;" />
            <TextField fx:id="usernameField" promptText="Choose a username (min 3 chars)"
                       style="-fx-padding: 9; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="4">
            <Label text="Role *" style="-fx-font-size: 12; -fx-text-fill: #555;" />
            <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                      style="-fx-padding: 4; -fx-border-color: #ccc; -fx-border-radius: 6;" />
        </VBox>

        <HBox spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Password *" style="-fx-font-size: 12; -fx-text-fill: #555;" />
                <PasswordField fx:id="passwordField" promptText="Min 6 characters"
                               style="-fx-padding: 9; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;" />
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Confirm Password *" style="-fx-font-size: 12; -fx-text-fill: #555;" />
                <PasswordField fx:id="confirmPasswordField" promptText="Repeat password"
                               style="-fx-padding: 9; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-background-radius: 6;" />
            </VBox>
        </HBox>

        <Label fx:id="messageLabel" text="" wrapText="true"
               style="-fx-font-size: 12;" maxWidth="360" />

        <Button text="✅  Create Account" onAction="#handleRegister" maxWidth="Infinity"
                style="-fx-background-color: #1b5e20; -fx-text-fill: white; -fx-font-size: 14;
                       -fx-font-weight: bold; -fx-padding: 11; -fx-background-radius: 6; -fx-cursor: hand;" />

        <Separator />

        <HBox alignment="CENTER" spacing="6">
            <Label text="Already have an account?" style="-fx-text-fill: #666; -fx-font-size: 12;" />
            <Button text="Sign In" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #1a237e;
                           -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-underline: true; -fx-padding: 0;" />
        </HBox>
    </VBox>
</StackPane>