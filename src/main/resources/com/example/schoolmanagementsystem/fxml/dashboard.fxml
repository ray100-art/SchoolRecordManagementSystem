<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.schoolmanagementsystem.controller.DashboardController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #f0f2f5;">

    <!-- TOP NAV BAR -->
    <top>
        <HBox style="-fx-background-color: #1a237e; -fx-padding: 14 20;" alignment="CENTER_LEFT" spacing="20">
            <Label text="🏫 School Management System"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel" text="Welcome!" style="-fx-text-fill: #b3c5ff; -fx-font-size: 13;" />
            <Label fx:id="userRoleLabel" text="" style="-fx-text-fill: #7986cb; -fx-font-size: 12;" />
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="30" style="-fx-padding: 30;">

            <Label text="Dashboard" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a237e;" />

            <!-- STATS CARDS -->
            <HBox spacing="20" alignment="CENTER">
                <!-- Students -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <Label text="👨‍🎓" style="-fx-font-size: 28;" />
                    <Label text="Total Students" style="-fx-text-fill: #666; -fx-font-size: 13;" />
                    <Label fx:id="totalStudentsLabel" text="0"
                           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a237e;" />
                </VBox>
                <!-- Teachers -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <Label text="👩‍🏫" style="-fx-font-size: 28;" />
                    <Label text="Total Teachers" style="-fx-text-fill: #666; -fx-font-size: 13;" />
                    <Label fx:id="totalTeachersLabel" text="0"
                           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" />
                </VBox>
                <!-- Subjects -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <Label text="📚" style="-fx-font-size: 28;" />
                    <Label text="Subjects" style="-fx-text-fill: #666; -fx-font-size: 13;" />
                    <Label fx:id="totalSubjectsLabel" text="0"
                           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #e65100;" />
                </VBox>
                <!-- Fees -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="120"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <Label text="💰" style="-fx-font-size: 28;" />
                    <Label text="Fees Collected" style="-fx-text-fill: #666; -fx-font-size: 13;" />
                    <Label fx:id="totalFeesLabel" text="KSh 0"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #6a1b9a;" />
                </VBox>
            </HBox>

            <!-- QUICK NAV BUTTONS -->
            <Label text="Quick Navigation" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #555;" />
            <TilePane hgap="16" vgap="16" prefColumns="3" alignment="CENTER">
                <Button text="👨‍🎓  Manage Students" onAction="#goToStudents" prefWidth="220" prefHeight="60"
                        style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
                <Button text="👩‍🏫  Manage Teachers" onAction="#goToTeachers" prefWidth="220" prefHeight="60"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
                <Button text="📚  Subjects" onAction="#goToSubjects" prefWidth="220" prefHeight="60"
                        style="-fx-background-color: #e65100; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
                <Button text="📝  Grades &amp; Marks" onAction="#goToGrades" prefWidth="220" prefHeight="60"
                        style="-fx-background-color: #0277bd; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
                <Button text="✅  Attendance" onAction="#goToAttendance" prefWidth="220" prefHeight="60"
                        style="-fx-background-color: #4a148c; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
                <Button text="💰  Fee Payments" onAction="#goToFees" prefWidth="220" prefHeight="60"
                        style="-fx-background-color: #880e4f; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
            </TilePane>
        </VBox>
    </center>
</BorderPane>
